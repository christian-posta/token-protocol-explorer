              "value": "{\n  \"typ\": \"dpop+jwt\",\n  \"alg\": \"ES256\",\n  \"jwk\": {\n    \"kty\": \"EC\",\n    \"x\": \"l8BFdamQrm6UmuEPY6r1qyJDlb3Ut3jXWiuKn4-GR3A\",\n    \"y\": \"_eKPsI_use_2fkzDjhhqq8qVe_2oVvIo5jLQ3Mh41uM\",\n    \"crv\": \"P-256\"\n  }\n}"
