        "Authorization": "DPoP eyJ0eXAiOiJhdCtqd3QiLCJhbGciOiJFUzI1NiJ9.eyJpc3MiOiJodHRwczovL2F1dGguZXhhbXBsZS5jb20iLCJzdWIiOiJ1c2VyMTIzIiwiYXVkIjoiaHR0cHM6Ly9hcGkuZXhhbXBsZS5jb20iLCJleHAiOjE1NjIyNjYyMTYsImlhdCI6MTU2MjI2MjYxNiwiY25mIjp7ImprdCI6IjBaaG03UE1VWHk4M3Ztdm91RmZIRmEydFlxTXdZVWg3aUNwVlhqUm82U2MifX0.mock_sig",
        "Content-Type": "application/json",
        "DPoP": "eyJ0eXAiOiJkcG9wK2p3dCIsImFsZyI6IkVTMjU2IiwiandrIjp7Imt0eSI6IkVDIiwieCI6Imw4QkZkYW1Rcm02VW11RVBZNnIxcXlKRGxiM1V0M2pYV2l1S240LUdSM0EiLCJ5IjoiX2VLUHNJX3VzZV8yZmt6akRqaHFxOHFWZV8yb1Z2SW81akxRM01oNDF1TSIsImNydiI6IlAtMjU2In19.eyJqdGkiOiJBaHROaXhsRThPZyIsImh0bSI6IlBPU1QiLCJodHUiOiJodHRwczovL2FwaS5leGFtcGxlLmNvbS9wcm90ZWN0ZWQiLCJpYXQiOjE1NjIyNjI2MTgsImF0aCI6InBfWkhocUlWVkZDN1lkYkdTQnFaLVRTY0E2WThsWENNSWJJdXR0TjI2dzAifQ.aBcDe..."
