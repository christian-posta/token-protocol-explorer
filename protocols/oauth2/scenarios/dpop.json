{
  "id": "oauth2-dpop-full-flow",
  "title": "OAuth 2.0 DPoP \u2014 Full Flow",
  "description": "Demonstrating Proof-of-Possession (DPoP) at the application layer. The client generates a DPoP proof to bind the access token to a private key, preventing token replay.",
  "rfc": "RFC 9449",
  "category": "OAuth 2.0 DPoP",
  "participants": [
    {
      "id": "client",
      "label": "Client Application",
      "type": "client"
    },
    {
      "id": "authz",
      "label": "Authz Server",
      "type": "idp"
    },
    {
      "id": "resource",
      "label": "Resource Server",
      "type": "server"
    }
  ],
